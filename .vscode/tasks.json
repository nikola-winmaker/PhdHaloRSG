{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup environment",
      "type": "shell",
      "command": "sudo bash tools/scripts/bootstrap_env.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Clean build all",
      "type": "shell",
      "command": "echo ${input:out_select} > .out_select && sudo make qemu-hart0-mmode USE_HALO=${input:useHalo} OUT_SELECT=${input:out_select}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [],
      "hide": true
    },
    {
      "label": "Clean build all & Run",
      "dependsOn": ["Clean build all", "Apps QEMU Console"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Hart1 Zephyr build",
      "type": "shell",
      "command": "sudo make zephyr-hart1-fast USE_HALO=${input:useHalo}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Hart2 FreeRTOS build",
      "type": "shell",
      "command": "sudo make -C apps/freertos-hart2 clean && make -C apps/freertos-hart2 app2 FREERTOS_KERNEL_DIR=${workspaceFolder}/deps/freertos/FreeRTOS-Kernel USE_HALO=${input:useHalo}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Hart3 BM build",
      "type": "shell",
      "command": "sudo make -C apps/bare-hart3 clean && make -C apps/bare-hart3 app3 USE_HALO=${input:useHalo}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Hart4 Linux build",
      "type": "shell",
      "command": "sudo make buildroot-linux-fast USE_HALO=${input:useHalo}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "OpenSBI Build",
      "type": "shell",
      "command": "make qemu-hart0-mmode",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "QEMU",
      "type": "shell",
      "command": "echo ${input:out_select} > .out_select && sudo make qemu-hart0-mmode-run OUT_SELECT=${input:out_select}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "never",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [],
      "hide": true
    },
  {
    "label": "Apps QEMU Console",
    "type": "shell",
    "hide": true,
    "command": "sudo python3 tools/console/qemu_apps_console.py",
    "options": { "cwd": "${workspaceFolder}" },
    "presentation": {
      "reveal": "always",
      "panel": "shared",
      "clear": true,
      "close": true
    },
    "problemMatcher": []
  },
  {
    "label": "QEMU Sys Run",
    "dependsOn": ["QEMU", "Apps QEMU Console"],
    "dependsOrder": "parallel",
    "problemMatcher": []
  },
    {
      "label": "Halo: Compose",
      "type": "shell",
      "command": "halo compose -a ${workspaceFolder}/halo_dist/hadls -o ${workspaceFolder}/deps/halo/hc_out/ --include-stdlib-profiles",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Halo: Generate",
      "type": "shell",
      "command": "sudo bash tools/scripts/halo_generate_all.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
  ],
  "inputs": [
    {
      "id": "useHalo",
      "type": "pickString",
      "description": "Select build mode",
      "options": [
        {
          "label": "HALO",
          "value": "1"
        },
        {
          "label": "Classical",
          "value": "0"
        }
      ],
      "default": "0"
    },
    {
      "id": "out_select",
      "type": "pickString",
      "description": "Select output mode",
      "options": [
        {
          "label": "console",
          "value": "stdio"
        },
        {
          "label": "script",
          "value": "pty"
        }
      ],
      "default": "stdio"
    }
  ]
}
