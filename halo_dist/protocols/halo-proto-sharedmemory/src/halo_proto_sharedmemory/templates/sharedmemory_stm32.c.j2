{% extends "sharedmemory_impl.c.j2" %}

{% block platform_includes %}
/* STM32 HAL includes (adjust based on specific STM32 variant) */
/* #include "stm32fxxx_hal.h" */
{% endblock %}

{% block platform_globals %}
/* STM32 synchronization using critical sections */
static volatile halo_u8_t shmem_lock_flag = 0;
{% endblock %}

{% block platform_sync_ops %}
void sharedmemory_lock(const sharedmemory_channel_t *chan) {
    /* STM32 critical section using interrupt disabling */
    if (chan->blocking) {
        /* Disable interrupts and busy-wait */
        while (shmem_lock_flag == 1) {
            __asm__ volatile("nop");
        }
        shmem_lock_flag = 1;
        #if defined(STM32F7xx) || defined(STM32H7xx) 
        __asm__ volatile("dmb" ::: "memory");
        #endif
    } else {
        /* Non-blocking attempt */
        #if defined(STM32F7xx) || defined(STM32H7xx)
        __asm__ volatile("dmb" ::: "memory");
        #endif
        shmem_lock_flag = 1;
    }
}

void sharedmemory_unlock(const sharedmemory_channel_t *chan) {
    /* STM32 release critical section */
    #if defined(STM32F7xx) || defined(STM32H7xx)
    __asm__ volatile("dmb" ::: "memory");
    #endif
    shmem_lock_flag = 0;
    #if defined(STM32F7xx) || defined(STM32H7xx)
    __asm__ volatile("dmb" ::: "memory");
    #endif
}
{% endblock %}

{% block platform_fence %}
void sharedmemory_fence_acquire(void) {
    /* STM32 ARM memory barrier for acquire semantics */
    #if defined(STM32F7xx) || defined(STM32H7xx)
    __asm__ volatile("dmb" ::: "memory");
    #else
    // Older STM32 variants may not have DMB instruction - use a compiler barrier
    #endif
}

void sharedmemory_fence_release(void) {
    /* STM32 ARM memory barrier for release semantics */
    #if defined(STM32F7xx) || defined(STM32H7xx)
    __asm__ volatile("dmb" ::: "memory");
    #else
    // Older STM32 variants may not have DMB instruction - use a compiler barrier
    #endif
}

void sharedmemory_fence_full(void) {
    /* STM32 ARM full memory barrier */
    #if defined(STM32F7xx) || defined(STM32H7xx)
    __asm__ volatile("dsb" ::: "memory");
    __asm__ volatile("isb" ::: "memory");
    #endif
}
{% endblock %}

{% block platform_cache %}
void sharedmemory_cache_flush(const sharedmemory_channel_t *chan,
                            halo_size_t offset, halo_size_t len) {
    /* STM32 cache flush using HAL (if present) or direct CMSIS-Core */
    if (chan->cacheable && chan->writeback) {
        /* For STM32H7x with D-Cache: use HAL_CleanDCacheSCB or SCB_CleanDCache_by_Addr */
        /* #ifdef STM32H7xx
           SCB_CleanDCache_by_Addr((uint32_t*)(chan->base + offset), len);
           #endif */
        #if defined(STM32F7xx) || defined(STM32H7xx)
        __asm__ volatile("dsb" ::: "memory");
        #endif
    }
}

void sharedmemory_cache_invalidate(const sharedmemory_channel_t *chan,
                                 halo_size_t offset, halo_size_t len) {
    /* STM32 cache invalidate using HAL (if present) or direct CMSIS-Core */
    if (chan->cacheable) {
        /* For STM32H7x with D-Cache: use HAL_CleanInvalidateDCacheSCB or SCB_InvalidateDCache_by_Addr */
        /* #ifdef STM32H7xx
           SCB_InvalidateDCache_by_Addr((uint32_t*)(chan->base + offset), len);
           #endif */
        #if defined(STM32F7xx) || defined(STM32H7xx)
        __asm__ volatile("dsb" ::: "memory");
        #endif
    }
}
{% endblock %}

