/* ============================================================================
 * Protocol API Implementation - Ring Buffer Transfer
 * ============================================================================ */

int sharedmemory_send(const sharedmemory_channel_t *chan, const void *src, halo_size_t len) {
    if (!chan || !chan->base || !src || len == 0 || len > chan->max_payload) {
        return -1;
    }
    
    sharedmemory_ringbuf_ctrl_t *ctrl = (sharedmemory_ringbuf_ctrl_t *)chan->base;
    
    /* Lock for exclusive write access */
    sharedmemory_lock(chan);
    
    /* Check if ring buffer is full (write_idx + 1 == read_idx) */
    halo_u32_t next_write = (ctrl->write_idx + 1) % ctrl->slot_count;
    if (next_write == ctrl->read_idx) {
        sharedmemory_unlock(chan);
        return -1; /* Ring buffer full */
    }
    
    /* Write message to the current write slot */
    halo_u32_t write_offset = sizeof(sharedmemory_ringbuf_ctrl_t) + (ctrl->write_idx * ctrl->slot_size);
    sharedmemory_header_t *header = (sharedmemory_header_t *)(chan->base + write_offset);
    
    header->size = len;
    header->valid = 0;
    header->sequence = ctrl->write_idx;
    header->crc_value = 0;
    header->integrity = SHAREDMEMORY_CRC_TYPE;
    header->reserved = 0;
    
    /* Copy payload after header */
    halo_u8_t *payload = (halo_u8_t *)(header + 1);
    memcpy((void *)payload, src, len);
    
    /* Calculate CRC if enabled */
    if (SHAREDMEMORY_CRC_TYPE != SHAREDMEMORY_CRC_NONE) {
        header->crc_value = sharedmemory_calculate_crc((const halo_u8_t *)payload, len);
    }
    
    /* Flush cache before marking message valid */
    sharedmemory_cache_flush(chan, write_offset, sizeof(sharedmemory_header_t) + len);
    
    /* Mark as valid */
    header->valid = 1;
    sharedmemory_fence_release();
    
    /* Advance write index */
    ctrl->write_idx = next_write;
    
    sharedmemory_unlock(chan);
    return 0;
}

int sharedmemory_recv(const sharedmemory_channel_t *chan, void *dst, halo_size_t len) {
    if (!chan || !chan->base || !dst || len == 0) {
        return -1;
    }
    
    sharedmemory_ringbuf_ctrl_t *ctrl = (sharedmemory_ringbuf_ctrl_t *)chan->base;
    
    /* Lock for exclusive read access */
    sharedmemory_lock(chan);
    
    /* Check if ring buffer is empty */
    if (ctrl->read_idx == ctrl->write_idx) {
        sharedmemory_unlock(chan);
        return 0; /* No data available */
    }
    
    /* Read message from current read slot */
    halo_u32_t read_offset = sizeof(sharedmemory_ringbuf_ctrl_t) + (ctrl->read_idx * ctrl->slot_size);
    sharedmemory_header_t *header = (sharedmemory_header_t *)(chan->base + read_offset);
    
    /* Invalidate cache to ensure fresh read */
    sharedmemory_cache_invalidate(chan, read_offset, sizeof(sharedmemory_header_t) + header->size);
    sharedmemory_fence_acquire();
    
    /* Check if message is valid */
    if (!header->valid) {
        sharedmemory_unlock(chan);
        return 0; /* Data not yet available */
    }
    
    /* Verify CRC if enabled */
    if (SHAREDMEMORY_CRC_TYPE != SHAREDMEMORY_CRC_NONE) {
        halo_u8_t *payload = (halo_u8_t *)(header + 1);
        halo_u32_t computed_crc = sharedmemory_calculate_crc(payload, header->size);
        if (computed_crc != header->crc_value) {
            sharedmemory_unlock(chan);
            return -1; /* CRC mismatch */
        }
    }
    
    /* Copy payload to destination */
    halo_size_t copy_len = (header->size < len) ? header->size : len;
    halo_u8_t *payload = (halo_u8_t *)(header + 1);
    memcpy(dst, (const void *)payload, copy_len);
    
    /* Mark as consumed */
    header->valid = 0;
    
    /* Advance read index */
    ctrl->read_idx = (ctrl->read_idx + 1) % ctrl->slot_count;
    
    sharedmemory_unlock(chan);
    return copy_len;
}

int sharedmemory_try_recv(const sharedmemory_channel_t *chan, void *dst, halo_size_t max_len, halo_size_t *actual_len) {
    /* Same as sharedmemory_recv but returns actual length through pointer */
    if (!actual_len) {
        return -1;
    }
    int result = sharedmemory_recv(chan, dst, max_len);
    if (result >= 0) {
        *actual_len = result;
    }
    return result;
}
