void sharedmemory_init(const sharedmemory_channel_t *chan) {
    /* Initialize channel */
    if (!chan || !chan->base) {
        return;
    }
    
    /* Set up ring buffer control block */
    sharedmemory_ringbuf_ctrl_t *ctrl = (sharedmemory_ringbuf_ctrl_t *)chan->base;
    ctrl->read_idx = 0;
    ctrl->write_idx = 0;
    ctrl->slot_count = (chan->size - sizeof(sharedmemory_ringbuf_ctrl_t)) / 
                       (sizeof(sharedmemory_header_t) + chan->max_payload);
    ctrl->slot_size = sizeof(sharedmemory_header_t) + chan->max_payload;
    
    {% block platform_init_extra %}
    /* Platform-specific init code */
    {% endblock %}
}

void sharedmemory_init_with_buffer(sharedmemory_channel_t *chan, void *buffer) {
    /* Initialize channel with external buffer address */
    if (!chan || !buffer) {
        return;
    }
    
    /* Override the base pointer with external buffer */
    chan->base = (volatile halo_u8_t *)buffer;
    
    /* Call standard initialization */
    sharedmemory_init(chan);
}

