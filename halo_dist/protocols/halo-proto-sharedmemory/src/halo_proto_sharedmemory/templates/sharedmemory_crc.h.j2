/* Shared CRC declarations for all platforms */
#ifndef SHAREDMEMORY_CRC_H
#define SHAREDMEMORY_CRC_H

#include "halo_types.h"

// Software CRC function declarations
halo_u16_t sharedmemory_crc16(const halo_u8_t *data, halo_size_t len);
halo_u32_t sharedmemory_crc32(const halo_u8_t *data, halo_size_t len);

/* Hardware CRC stubs - platform overrides these if HW accelerator available */
/* Default implementations return 0 (no-op). Override in platform-specific code. */
halo_u16_t sharedmemory_hw_crc16(const halo_u8_t *data, halo_size_t len);
halo_u32_t sharedmemory_hw_crc32(const halo_u8_t *data, halo_size_t len);

#endif /* SHAREDMEMORY_CRC_H */
