{% extends "sharedmemory_impl.c.j2" %}

{% block platform_globals %}
/* Baremetal synchronization using spinlocks */
static volatile halo_u8_t shmem_spinlock = 0;
{% endblock %}

{% block platform_primitives %}
/* Inline assembly for atomic test-and-set */
static inline halo_u8_t atomic_test_and_set(volatile halo_u8_t *ptr) {
#if defined(__ARM_ARCH) && (__ARM_ARCH >= 7)
    halo_u8_t result, tmp;
    __asm__ volatile(
        "1: ldrexb %0, [%2]\n"
        "   mov %1, #1\n"
        "   strexb %1, %1, [%2]\n"
        "   cmp %1, #0\n"
        "   bne 1b\n"
        "   dmb\n"
        : "=&r"(result), "=&r"(tmp)
        : "r"(ptr)
        : "cc", "memory"
    );
    return result;
#else
    /* Generic fallback - disable interrupts */
    halo_u8_t result = *ptr;
    *ptr = 1;
    return result;
#endif
}

static inline void atomic_release(volatile halo_u8_t *ptr) {
#if defined(__ARM_ARCH) && (__ARM_ARCH >= 7)
    __asm__ volatile("dmb" ::: "memory");
#endif
    *ptr = 0;
}
{% endblock %}

{% block platform_sync_ops %}
void sharedmemory_lock(const sharedmemory_channel_t *chan) {
    if (chan->blocking) {
        /* Spinlock - wait until we acquire */
        while (atomic_test_and_set(&shmem_spinlock)) {
            /* Spin */
        }
    } else {
        /* Try once */
        atomic_test_and_set(&shmem_spinlock);
    }
}

void sharedmemory_unlock(const sharedmemory_channel_t *chan) {
    atomic_release(&shmem_spinlock);
}
{% endblock %}

{% block platform_fence %}
void sharedmemory_fence_acquire(void) {
#if defined(__ARM_ARCH) && (__ARM_ARCH >= 7)
    __asm__ volatile("dmb" ::: "memory");
#else
    __asm__ volatile("" ::: "memory");
#endif
}

void sharedmemory_fence_release(void) {
#if defined(__ARM_ARCH) && (__ARM_ARCH >= 7)
    __asm__ volatile("dmb" ::: "memory");
#else
    __asm__ volatile("" ::: "memory");
#endif
}

void sharedmemory_fence_full(void) {
#if defined(__ARM_ARCH) && (__ARM_ARCH >= 7)
    __asm__ volatile("dsb" ::: "memory");
    __asm__ volatile("isb" ::: "memory");
#else
    __asm__ volatile("" ::: "memory");
#endif
}
{% endblock %}

{% block platform_cache %}
void sharedmemory_cache_flush(const sharedmemory_channel_t *chan,
                            halo_size_t offset, halo_size_t len) {
    /* Baremetal cache flush - ARM CMSIS variant */
    if (chan->cacheable && chan->writeback) {
#if defined(__ARM_ARCH) && (__ARM_ARCH >= 7)
        /* For ARMv7-M (e.g., STM32, Cortex-M): clean D-cache by address range */
        /* Requires CMSIS/Core support or direct MPU configuration */
        /* Example: SCB_CleanDCache_by_Addr((uint32_t*)(chan->base + offset), len); */
        __asm__ volatile("dsb" ::: "memory");
#else
        /* Generic barrier */
        __asm__ volatile("" ::: "memory");
#endif
    }
}

void sharedmemory_cache_invalidate(const sharedmemory_channel_t *chan,
                                 halo_size_t offset, halo_size_t len) {
    /* Baremetal cache invalidate - ARM CMSIS variant */
    if (chan->cacheable) {
#if defined(__ARM_ARCH) && (__ARM_ARCH >= 7)
        /* For ARMv7-M (e.g., STM32, Cortex-M): invalidate D-cache by address range */
        /* Requires CMSIS/Core support or direct cache control */
        /* Example: SCB_InvalidateDCache_by_Addr((uint32_t*)(chan->base + offset), len); */
        __asm__ volatile("dsb" ::: "memory");
#else
        /* Generic barrier */
        __asm__ volatile("" ::: "memory");
#endif
    }
}
{% endblock %}
