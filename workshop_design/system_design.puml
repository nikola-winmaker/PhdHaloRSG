@startuml
title AMP Battery Charging System (HALO Workshop Scenario)

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Monospace
skinparam rectangle {
  RoundCorner 12
  BorderColor #333333
}
skinparam note {
  BorderColor #666666
  BackgroundColor #FFF9D6
}

left to right direction

rectangle "RISC-V AMP System" as SYS #F7F7F7 {

  rectangle "Hart0\nS7 Core\nM-mode" as H0 #97C97C {
    rectangle "Boot Coordinator" as H0A #CFE8C8
  }

  rectangle "Hart1\nU74 Core\nM-mode" as H1 #B7D9EA {
    rectangle "Zephyr RTOS" as H1A #DDECF6
    rectangle "Sensor Fusion\n---\nbattery_temp\nbattery_voltage\ncharge_current\ncbreaker" as H1B #EAF4FB
  }

  rectangle "Hart2\nU74 Core\nM-mode" as H2 #B7D9EA {
    rectangle "FreeRTOS" as H2A #DDECF6
    rectangle "Charge Controller" as H2B #EAF4FB
  }

  rectangle "Hart3\nU74 Core\nM-mode" as H3 #B7D9EA {
    rectangle "Bare-metal App" as H3A #DDECF6
    rectangle "Safety Monitor" as H3B #EAF4FB
  }

  rectangle "Shared Memory IPC" as SHM #EDEDED

  rectangle "Hart4\nU74 Core" as H4 #FFD76A {
    rectangle "OpenSBI Bootloader\nM-mode" as H4A #FFE8A6
    rectangle "Linux Kernel\nS-mode" as H4B #8DB5F0
    rectangle "Linux Supervisor\nCLI Parser / Logger" as H4C #C9DCF8
  }

  rectangle "Shared Services" as SH #EDEDED {
    rectangle "Peripherals" as PER #F5F5F5
    rectangle "UART Console" as UART #F5F5F5
  }

  rectangle "External Operator" as OP #FFF9D6
}

note top of SYS
S7 Hart0 boots the platform and releases the application harts.
Hart1 / Zephyr = sensing and telemetry aggregation.
Hart2 / FreeRTOS = charging control logic.
Hart3 / Bare-metal = safety enforcement.
Hart4 / Linux = UART command parsing, supervision, logging.
end note

' =========================
' PLATFORM / SERVICE ACCESS
' =========================

H0 --> SH : init services
H1 --> SH : use peripherals
H2 --> SH : use IPC
H3 --> SH : use IPC
H4 --> SH : use UART and IPC

' =========================
' EXTERNAL COMMAND PATH
' =========================

OP --> UART : user command text
UART --> H4C : UartConsoleCommandIf

' =========================
' APPLICATION IPC FLOWS
' =========================

H1B --> SHM : SensorFrameIf
SHM --> H2B : SensorFrameIf

H2B --> SHM : ChargeCommandIf
SHM --> H3B : ChargeCommandIf

H2B --> SHM : ChargeStatusIf
SHM --> H4C : ChargeStatusIf

H3B --> SHM : SafetyStateIf
SHM --> H4C : SafetyStateIf

H4C --> SHM : OperatorCommandIf
SHM --> H2B : OperatorCommandIf

' =========================
' LOCAL LINUX PROCESSING
' =========================

H4C --> H4C : parse UART text\nvalidate command\ntranslate to OperatorCommandIf

@enduml