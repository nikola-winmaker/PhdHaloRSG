/ {
	chosen {
		/*
		 * Align the active Zephyr image with the legacy Hart 1 UART loader
		 * path used by Hart 0, which copies app1.bin to 0x80240000 and
		 * starts hart 1 from that address.
		 */
		zephyr,sram = &hart1_app_ram;
	};

	hart1_app_ram: memory@80240000 {
		device_type = "memory";
		reg = <0x0 0x80240000 0x0 0x00040000>;
		reg-names = "mem";
	};
};

&clint {
	interrupts-extended = <&cpu1_intc 3 &cpu1_intc 7>;
};

&plic {
	interrupts-extended = <&cpu1_intc 11>;
};
