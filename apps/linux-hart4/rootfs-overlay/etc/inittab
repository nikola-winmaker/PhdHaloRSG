# /etc/inittab for Buildroot overlay - disables all getty/login on serial consoles
# Comment out all getty lines to prevent login prompts on UARTs
#ttyS0::respawn:/sbin/getty -L ttyS0 115200 vt100
#ttyS1::respawn:/sbin/getty -L ttyS1 115200 vt100
#ttyS2::respawn:/sbin/getty -L ttyS2 115200 vt100
#ttyS3::respawn:/sbin/getty -L ttyS3 115200 vt100
::sysinit:/etc/init.d/rcS
::shutdown:/bin/umount -a -r
::restart:/sbin/init
