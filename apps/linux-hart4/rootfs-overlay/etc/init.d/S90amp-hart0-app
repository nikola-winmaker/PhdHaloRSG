#!/bin/sh

case "$1" in
    start)
        mkdir -p /dev
        echo "[init] starting linux_app"
        /usr/bin/linux_app </dev/console >/dev/console 2>&1 
        ;;
    stop)
        killall linux_app 2>/dev/null || true
        ;;
    restart)
        "$0" stop
        "$0" start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
