@startuml
title AMP Vehicle Supervision System (HALO Workshop Scenario)

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Monospace
skinparam rectangle {
  RoundCorner 12
  BorderColor #333333
}
skinparam note {
  BorderColor #666666
  BackgroundColor #FFF9D6
}

left to right direction

rectangle "RISC-V AMP System" as SYS #F7F7F7 {

  rectangle "Hart0\nS7 Core\nM-mode" as H0 #97C97C {
    rectangle "Boot Coordinator" as H0A #CFE8C8
  }

  rectangle "Hart1\nU74 Core\nM-mode" as H1 #B7D9EA {
    rectangle "Zephyr RTOS" as H1A #DDECF6
    rectangle "Sensor Fusion\n---\nbattery_temp\ninverter_temp\nvoltage\ncurrent\ncbreaker" as H1B #EAF4FB
  }

  rectangle "Hart2\nU74 Core\nM-mode" as H2 #B7D9EA {
    rectangle "FreeRTOS" as H2A #DDECF6
    rectangle "Control Logic" as H2B #EAF4FB
  }

  rectangle "Hart3\nU74 Core\nM-mode" as H3 #B7D9EA {
    rectangle "Bare-metal App" as H3A #DDECF6
    rectangle "Safety Monitor" as H3B #EAF4FB
  }

  rectangle "Shared Memory IPC" as SHM #EDEDED

  rectangle "Hart4\nU74 Core" as H4 #FFD76A {
    rectangle "OpenSBI Bootloader\nM-mode" as H4A #FFE8A6
    rectangle "Linux Kernel\nS-mode" as H4B #8DB5F0
    rectangle "Linux Userspace\nApplication" as H4C #C9DCF8
    rectangle "Logger / CLI" as H4D #EAF1FF
  }

  rectangle "Shared Services" as SH #EDEDED {
    rectangle "Peripherals" as CLINT #F5F5F5
    rectangle "UART Console" as UART #F5F5F5
  }
}

note top of SYS
S7 Hart0 boots system and releases the other harts.
Zephyr = sensing, FreeRTOS = control, Bare-metal = safety, Linux = monitoring.
end note

' =========================
' SYSTEM ACCESS
' =========================

H0 --> SH : init services
H1 --> SH : use peripherals
H2 --> SH : use peripherals
H3 --> SH : use peripherals
H4 --> SH : user I/O

' =========================
' IPC FLOWS
' =========================

H1B --> SHM : SensorFrame
SHM --> H2B : SensorFrame

H1B --> SHM : FaultEvent
SHM --> H2B : FaultEvent

H2B --> SHM : ControlCommand
SHM --> H3B : ControlCommand

H2B --> SHM : ControlStatus
SHM --> H4C : ControlStatus

H3B --> SHM : SafetyState
SHM --> H4C : SafetyState

H4C --> SHM : OperatorCommand
SHM --> H2B : OperatorCommand

' =========================
' LOCAL FLOW
' =========================

H4C --> H4D : log output
H4D --> UART : print

@enduml