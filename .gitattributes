# Auto detect text files and normalize line endings to LF
* text=auto

# Source code files
*.c text eol=lf
*.h text eol=lf
*.cpp text eol=lf
*.hpp text eol=lf
*.cc text eol=lf
*.cxx text eol=lf
*.hh text eol=lf
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.java text eol=lf
*.rs text eol=lf
*.go text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# Configuration files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.env text eol=lf

# Build-related files
Makefile text eol=lf
CMakeLists.txt text eol=lf
*.cmake text eol=lf
Dockerfile text eol=lf
*.mk text eol=lf

# Documentation files
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf
*.adoc text eol=lf

# Linker scripts and device tree
*.ld text eol=lf
*.dts text eol=lf
*.dtsi text eol=lf

# Assembly files
*.S text eol=lf
*.s text eol=lf
*.asm text eol=lf

# HDL/Hardware description
*.v text eol=lf
*.vhd text eol=lf
*.vhdl text eol=lf

# Binary files
*.bin binary
*.elf binary
*.o binary
*.a binary
*.so binary
*.dll binary
*.exe binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.tar binary
*.gz binary
*.wheel binary
*.whl binary
